; @solana-program/zk-elgamal-proof@0.1.0 still declares a peer on @solana/kit ^5,
; while @solana-program/token-2022@0.11.0 (which depends on it) requires kit ^6.
; They are runtime-compatible; this relaxes npm's peer-dep check so the kit-6
; stack installs cleanly (and keeps `npm install`/CI working without a flag).
legacy-peer-deps=true
